# =============================================================================
# MealfitRD frontend — .env.example
# =============================================================================
# Copia este archivo a `.env` y rellena los valores. **NUNCA commitees `.env`**.
# Todas las VITE_* terminan en el bundle del cliente (público por diseño) —
# úsalas SOLO para identificadores que el browser pueda ver.
# Secretos (PayPal SECRET, Supabase service_role, etc.) van en backend/.env.
# =============================================================================

# ----- API rutas -------------------------------------------------------------
VITE_API_URL=/api/analyze
VITE_LIKE_WEBHOOK=/api/like
VITE_SWAP_WEBHOOK=/api/swap-meal

# [F-P1-4 · 2026-05-23] Base URL del backend FastAPI. Leído por
# `src/config/api.js:6` con fallback a string vacío ('') en producción.
#
# Cuándo setearlo:
#   - Dev local: NO setear — el código detecta `import.meta.env.DEV` y
#     apunta a `http://127.0.0.1:3001` directamente (el proxy de vite.config.js
#     reescribe /api → 127.0.0.1:3001 para evitar CORS).
#   - Producción Vercel (mismo dominio frontend+backend): NO setear.
#     El fallback a '' produce URLs relativas tipo `/api/...` que el browser
#     resuelve al mismo host (Vercel rewrites apuntan al backend).
#   - Producción cross-domain: SETEAR a la URL absoluta del backend
#     (`https://api.mealfitrd.com`). Sin esto, fetch a `/api/...` falla
#     silenciosamente (404 o CORS) sin pista en logs.
#
# Modo de fallo silencioso pre-doc: si el operador setea el frontend en
# `app.mealfitrd.com` y el backend en `api.mealfitrd.com` sin configurar
# este env var, TODAS las requests del frontend caen a `app.mealfitrd.com/api/...`
# que no existe → 404 sin diagnóstico claro.
# VITE_API_BASE_URL=https://api.mealfitrd.com

# ----- Supabase client (browser) — anon-key es PÚBLICA por diseño -----------
# [P1-AUDIT-2 · 2026-05-12] Movido de `src/supabase.js` hardcoded. El anon-key
# viaja al browser y solo concede acceso filtrado por RLS — NO es secreto.
# Pero hardcodearlo impide tener staging/prod separados sin builds distintos.
# El backend usa SERVICE_ROLE (en `backend/.env`) que SÍ es secreto.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<supabase-anon-jwt>


# ----- PayPal (client-side: Client ID + Plan IDs son PUBLIC) -----------------
VITE_PAYPAL_CLIENT_ID=<paypal-client-id>

VITE_PAYPAL_PLAN_BASIC=<paypal-plan-id-basic-monthly>
VITE_PAYPAL_PLAN_PLUS=<paypal-plan-id-plus-monthly>
VITE_PAYPAL_PLAN_ULTRA=<paypal-plan-id-ultra-monthly>

VITE_PAYPAL_PLAN_BASIC_ANNUAL=<paypal-plan-id-basic-annual>
VITE_PAYPAL_PLAN_PLUS_ANNUAL=<paypal-plan-id-plus-annual>
VITE_PAYPAL_PLAN_ULTRA_ANNUAL=<paypal-plan-id-ultra-annual>

# ----- Observabilidad (frontend Sentry — DSN distinto del backend) ----------
VITE_SENTRY_DSN=<sentry-dsn-frontend>

# [P1-SENTRY-SAMPLE-COST · 2026-05-12] Sample rate de tracing en el browser.
# Default código = 0.1 (10%). Subir a 1.0 SOLO para debug intensivo de un
# deploy específico; a 1.0 con tráfico moderado se agota la cuota mensual de
# Sentry en horas y los errores son throttled. Clamp [0.0, 1.0]; valores
# fuera de rango caen al default.
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# ----- Web Push (PUBLIC key only — la privada vive en backend/.env) ---------
VITE_VAPID_PUBLIC_KEY=<vapid-public-key>

# =============================================================================
# [P1-AUDIT-2 · 2026-05-12] CERRADO: VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY
# arriba. `src/supabase.js` ya los lee con fallback al valor legacy para
# back-compat por 1 release. Tras 1 release sin reportes, eliminar el fallback.
# =============================================================================
