# =============================================================================
# MealfitRD frontend — .env.example
# =============================================================================
# Copia este archivo a `.env` y rellena los valores. **NUNCA commitees `.env`**.
# Todas las VITE_* terminan en el bundle del cliente (público por diseño) —
# úsalas SOLO para identificadores que el browser pueda ver.
# Secretos (PayPal SECRET, Supabase service_role, etc.) van en backend/.env.
# =============================================================================

# ----- API rutas -------------------------------------------------------------
# [P2-API-BASE-CONTRACT · 2026-05-30] Origen del backend FastAPI. Es la ÚNICA
# var que `src/config/api.js` lee para construir `API_BASE`.
#   - VACÍO  → llamadas same-origin (`/api/...`). Usar SOLO si el SPA y FastAPI
#     comparten origen (reverse-proxy / nginx en el VPS Oracle sirviendo ambos).
#   - URL    → deploy cross-origin (un host estático sirve el SPA, FastAPI en
#     otro host). En ese caso DEBE setearse al build (Vite inlinea en build).
# Si falta en un build cross-origin, la config de nginx (que enruta `/api/` al
# backend) hace que las llamadas fallen ALTO (404) en vez de devolver HTML.
VITE_API_BASE_URL=
VITE_API_URL=/api/analyze

# ----- Neon Auth (browser) — el Auth Base URL es PÚBLICO por diseño ----------
# [P1-NEON-AUTH-MIGRATION · 2026-06-13] Reemplaza VITE_SUPABASE_URL/ANON_KEY.
# `src/supabase.js` crea el cliente de Neon Auth (Better Auth) con este URL via
# @neondatabase/neon-js. El backend valida los JWTs EdDSA contra el JWKS
# expuesto en <VITE_NEON_AUTH_URL>/.well-known/jwks.json. No hay secreto del
# lado cliente — el server secret key de Neon Auth vive en el panel de Neon.
VITE_NEON_AUTH_URL=https://<ep-id>.neonauth.<region>.aws.neon.tech/neondb/auth


# ----- PayPal (client-side: Client ID + Plan IDs son PUBLIC) -----------------
VITE_PAYPAL_CLIENT_ID=<paypal-client-id>

VITE_PAYPAL_PLAN_BASIC=<paypal-plan-id-basic-monthly>
VITE_PAYPAL_PLAN_PLUS=<paypal-plan-id-plus-monthly>
VITE_PAYPAL_PLAN_ULTRA=<paypal-plan-id-ultra-monthly>

VITE_PAYPAL_PLAN_BASIC_ANNUAL=<paypal-plan-id-basic-annual>
VITE_PAYPAL_PLAN_PLUS_ANNUAL=<paypal-plan-id-plus-annual>
VITE_PAYPAL_PLAN_ULTRA_ANNUAL=<paypal-plan-id-ultra-annual>

# ----- Observabilidad (frontend Sentry — DSN distinto del backend) ----------
VITE_SENTRY_DSN=<sentry-dsn-frontend>

# [P1-SENTRY-SAMPLE-COST · 2026-05-12] Sample rate de tracing en el browser.
# Default código = 0.1 (10%). Subir a 1.0 SOLO para debug intensivo de un
# deploy específico; a 1.0 con tráfico moderado se agota la cuota mensual de
# Sentry en horas y los errores son throttled. Clamp [0.0, 1.0]; valores
# fuera de rango caen al default.
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# ----- Analítica de producto (PostHog — usuarios activos / embudo / pagos) ---
# [POSTHOG-ANALYTICS · 2026-07-12] Gated: SIN key el frontend NO carga PostHog
# (no-op total). Consíguela en posthog.com → Project Settings → Project API Key.
# Host: US = https://us.i.posthog.com | EU = https://eu.i.posthog.com
VITE_POSTHOG_KEY=<posthog-project-api-key>
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ----- Web Push (PUBLIC key only — la privada vive en backend/.env) ---------
VITE_VAPID_PUBLIC_KEY=<vapid-public-key>

# =============================================================================
# [P1-NEON-AUTH-MIGRATION · 2026-06-13] Supabase eliminado por completo (Auth +
# datos). `src/supabase.js` throwea si VITE_NEON_AUTH_URL falta — sin fallback
# hardcoded. Datos: el frontend habla con el backend FastAPI (VITE_API_BASE_URL).
# =============================================================================
